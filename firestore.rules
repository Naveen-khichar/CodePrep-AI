rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the document belongs to the authenticated user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Progress Collection rules
    match /progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Submissions Collection rules
    match /submissions/{submissionId} {
      // Allow creation only if authenticated and setting their own userId
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Allow reading only if the submission belongs to the authenticated user
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Deny modifications and deletions (Audit trail integrity)
      allow update, delete: if false;
    }
  }
}
